<Application x:Class="PrivacyMasker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
  <Application.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextBrush" Color="#18202A" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#617083" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2E7D6B" />
  </Application.Resources>
</Application>
