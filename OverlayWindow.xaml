<Window x:Class="PrivacyMasker.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="Manual">
  <Border x:Name="MaskBorder"
          Background="#E61B2733"
          BorderBrush="#CC2E7D6B"
          BorderThickness="2"
          ClipToBounds="True">
    <Grid>
      <Image x:Name="MaskImage"
             Stretch="Uniform"
             Opacity="0.92"
             Visibility="Collapsed" />
      <StackPanel x:Name="DefaultTextPanel"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <TextBlock x:Name="PresetMessageText"
                   Text="不可以偷看哦"
                   Foreground="White"
                   FontSize="30"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="520" />
        <TextBlock x:Name="WindowTitleText"
                   Margin="0,10,0,0"
                   Foreground="#DCE5EA"
                   FontSize="14"
                   TextAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   MaxWidth="420" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
