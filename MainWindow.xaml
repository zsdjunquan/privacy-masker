<Window x:Class="PrivacyMasker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Privacy Masker"
        Width="520"
        Height="520"
        MinWidth="480"
        MinHeight="500"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" LastChildFill="True">
      <Border Width="42"
              Height="42"
              CornerRadius="8"
              Background="#2E7D6B"
              DockPanel.Dock="Left"
              Margin="0,0,14,0">
        <TextBlock Text="P"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>
      <StackPanel>
        <TextBlock Text="Privacy Masker"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}" />
        <TextBlock Text="屏幕共享时自动遮住微信、QQ 等私密聊天窗口"
                   Margin="0,4,0,0"
                   Foreground="{StaticResource MutedTextBrush}" />
      </StackPanel>
    </DockPanel>

    <Border Grid.Row="1"
            Margin="0,24,0,18"
            Padding="18"
            Background="White"
            CornerRadius="8"
            BorderBrush="#DDE4EA"
            BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock x:Name="StatusTitle"
                     Text="隐私模式已关闭"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextBrush}" />
          <TextBlock x:Name="StatusSubtitle"
                     Text="开启后会自动遮罩微信、QQ 窗口。快捷键：Ctrl + Alt + P"
                     Margin="0,6,0,0"
                     Foreground="{StaticResource MutedTextBrush}"
                     TextWrapping="Wrap" />
          <CheckBox x:Name="ShowLocalMaskCheckBox"
                    Content="本机显示遮罩"
                    IsChecked="True"
                    Margin="0,12,0,0"
                    Foreground="{StaticResource TextBrush}" />
          <Button x:Name="SafeShareButton"
                  Content="打开安全共享窗口"
                  Width="150"
                  Height="32"
                  HorizontalAlignment="Left"
                  Margin="0,12,0,0"
                  Click="SafeShareButton_Click"
                  Background="#18202A"
                  Foreground="White"
                  BorderThickness="0" />
        </StackPanel>
        <Button x:Name="ToggleButton"
                Grid.Column="1"
                Width="120"
                Height="38"
                Margin="18,0,0,0"
                Click="ToggleButton_Click"
                Background="#2E7D6B"
                Foreground="White"
                BorderThickness="0"
                Content="开启保护" />
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Padding="16"
            Background="White"
            CornerRadius="8"
            BorderBrush="#DDE4EA"
            BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel>
          <TextBlock Text="当前遮罩窗口"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextBrush}" />
          <TextBlock x:Name="ProtectedCountText"
                     Text="0 个"
                     Foreground="{StaticResource MutedTextBrush}"
                     HorizontalAlignment="Right"
                     DockPanel.Dock="Right" />
        </DockPanel>
        <ListBox x:Name="ProtectedWindowsList"
                 Grid.Row="1"
                 Margin="0,12,0,0"
                 BorderThickness="0"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Padding="10"
                      Margin="0,0,0,8"
                      Background="#F4F6F8"
                      CornerRadius="6">
                <StackPanel>
                  <TextBlock Text="{Binding Title}"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource TextBrush}"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding ProcessName}"
                             Margin="0,4,0,0"
                             FontSize="12"
                             Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <TextBlock Grid.Row="3"
               Margin="0,14,0,0"
               Foreground="{StaticResource MutedTextBrush}"
               TextWrapping="Wrap"
               Text="V0.2 原型：会议里请选择共享“Privacy Masker - 安全共享窗口”。普通桌面共享仍然会展示本机实际画面。" />
  </Grid>
</Window>
